# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=...
SUPABASE_PROJECT_REF=your-project-ref

# Shared secret between Vapi → edge function
# Set via `supabase secrets set VAPI_SHARED_SECRET=...`
# Then paste the same value into Vapi assistant's server.headers["x-vapi-secret"]
VAPI_SHARED_SECRET=replace-me-with-32-chars-of-randomness

# Vapi (only needed if you script assistant updates via API)
VAPI_API_KEY=
VAPI_ASSISTANT_ID=
